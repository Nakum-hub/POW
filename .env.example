# ---------------------------------------------------------------------------
# SkillOS environment configuration
# Copy this file to `.env` and fill in the values for your chosen mode.
# Only the VITE_* variables are read by the frontend (Vite). The non-prefixed
# variables at the bottom are Supabase Edge Function secrets and must be set
# with `supabase secrets set` (never committed, never shipped to the browser).
# ---------------------------------------------------------------------------

# --- Frontend (Vite) -------------------------------------------------------

# Live backend credentials. Copy from Supabase: Project Settings > API.
# Required for "live" mode. Leave as-is to run a backend-free demo (see below).
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Local sandbox/demo mode. When true, the app serves seeded data with no backend.
# This pair only takes effect during local development (`npm run dev`); it is
# intentionally ignored in production builds so a misconfigured deploy can never
# silently serve seeded data to real buyers.
VITE_FORCE_DEMO_MODE=false
VITE_ALLOW_SANDBOX_MODE=false

# Public demo deployment. Set to true ONLY when you intend to host a live,
# backend-free demo (e.g. GitHub Pages). Unlike the pair above, this IS honored
# in production builds, so set it deliberately. Leave unset/false for the real product.
VITE_PUBLIC_DEMO=false

# Optional. Shows a small "sandbox workspace" badge in demo mode when "true".
VITE_SHOW_ENVIRONMENT_BADGE=false

# Optional. Overrides environment detection ("production" | "development").
# Normally you do not need to set this.
# VITE_APP_ENV=production

# Optional. Sub-path the app is served from. Used at BUILD time only.
# Leave unset (defaults to "/") for root hosting (Vercel/Netlify/custom domain).
# Set to "/POW/" for a GitHub Pages project site at https://<user>.github.io/POW/.
# VITE_BASE_PATH=/POW/

# --- Supabase Edge Function secrets (NOT exposed to the browser) -----------
# Set these with: supabase secrets set KEY=value
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site origin(s) used for Edge Function CORS allow-listing.
SITE_URL=https://your-production-domain.com
ALLOWED_ORIGIN=https://your-production-domain.com

# Optional. Enables AI-generated project explanations in the explain-repo
# function. If omitted, a deterministic fallback summary is used instead.
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Razorpay billing (growth/scale self-serve checkout). Required for live
# billing; without these, create-razorpay-order returns 503 and the Billing
# page's upgrade buttons surface a "not configured yet" error instead of
# failing silently. RAZORPAY_WEBHOOK_SECRET is set separately when you
# create the webhook in the Razorpay Dashboard (Settings > Webhooks) --
# it is NOT the same value as RAZORPAY_KEY_SECRET.
RAZORPAY_KEY_ID=rzp_live_or_test_key_id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
